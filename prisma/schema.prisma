generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id           String     @id @default(cuid())
    email        String     @unique
    passwordHash String
    name         String?
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt
    sessions     Session[]
    documents    Document[]
    comments     Comment[]
    vault        VaultBlob?
    resetTokens  PasswordResetToken[]
}

model Session {
    id        String   @id @default(cuid())
    token     String   @unique
    userId    String
    expiresAt DateTime
    createdAt DateTime @default(now())
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([expiresAt])
}

model Document {
    id           String    @id
    title        String
    content      String
    pages        Json
    activePageId String
    ownerId      String
    isPublic      Boolean  @default(false)
    sharedPageIds String[]
    createdAt    DateTime
    updatedAt    DateTime
    owner        User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    comments     Comment[]
    docPages     Page[]
    sharedPages  SharedPage[]

    @@index([ownerId])
    @@index([updatedAt])
    @@index([isPublic])
}

model Page {
    id         String    @id
    documentId String
    title      String
    content    String
    position   Int
    isShared   Boolean   @default(false)
    createdAt  DateTime
    updatedAt  DateTime
    document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
    comments   Comment[]

    @@index([documentId])
    @@index([documentId, position])
    @@index([documentId, isShared])
}

model SharedPage {
    id         String   @id @default(cuid())
    documentId String
    pageId     String
    createdAt  DateTime @default(now())
    document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

    @@unique([documentId, pageId])
    @@index([documentId])
}

model Comment {
    id         String   @id
    documentId String
    pageId     String?
    userId     String
    content    String
    author     String
    createdAt  DateTime
    document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
    page       Page?     @relation(fields: [pageId], references: [id], onDelete: Cascade)
    user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([documentId])
    @@index([pageId])
    @@index([userId])
}

model VaultBlob {
    id        String   @id @default(cuid())
    userId    String   @unique
    blob      String
    updatedAt DateTime @updatedAt
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
    id        String   @id @default(cuid())
    token     String   @unique
    userId    String
    expiresAt DateTime
    createdAt DateTime @default(now())
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([expiresAt])
}
